import { Injectable } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { RedisService } from '../redis/redis.service';

@Injectable()
export class TransparencyService {
  constructor(private prisma: PrismaService, private redis: RedisService) {}

  async getPlatformStats() {
    const cacheKey = 'transparency:stats';
    const cached = await this.redis.get(cacheKey);
    if (cached) return JSON.parse(cached);

    const [stats, categoryBreakdown, monthlyGrowth, recentTx] = await Promise.all([
      this.prisma.platformStats.findUnique({ where: { id: 'singleton' } }),
      this.prisma.fundAllocation.groupBy({
        by: ['category'],
        _sum: { amount: true },
        where: { isPublic: true },
      }),
      this.prisma.$queryRaw`
        SELECT DATE_TRUNC('month', created_at) as month,
               SUM(amount_usd) as total
        FROM donations
        WHERE status = 'COMPLETED'
        GROUP BY 1 ORDER BY 1 LIMIT 12
      `,
      this.prisma.transaction.findMany({
        where: { status: 'COMPLETED', type: 'DONATION' },
        orderBy: { processedAt: 'desc' },
        take: 20,
        include: { donation: { include: { campaign: { select: { title: true } } } } },
      }),
    ]);

    const result = { stats, categoryBreakdown, monthlyGrowth, recentTx };
    await this.redis.set(cacheKey, JSON.stringify(result), 30);
    return result;
  }

  async getPublicLedger(page = 1, limit = 50) {
    return this.prisma.transaction.findMany({
      where: { status: 'COMPLETED', type: 'DONATION' },
      select: {
        id: true, amount: true, currency: true, processedAt: true,
        donation: {
          select: {
            isAnonymous: true,
            message: true,
            campaign: { select: { title: true, country: true } },
          },
        },
      },
      orderBy: { processedAt: 'desc' },
      skip: (page - 1) * limit,
      take: limit,
    });
  }

  async getFundAllocations(campaignId?: string) {
    return this.prisma.fundAllocation.findMany({
      where: { isPublic: true, ...(campaignId && { campaignId }) },
      include: { campaign: { select: { title: true } }, ngo: { select: { organizationName: true } } },
      orderBy: { allocatedAt: 'desc' },
    });
  }
}


