import { Injectable, NotFoundException, ConflictException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { AuditService } from '../audit/audit.service';
import { NGOApplicationDto } from './dto/ngo-application.dto';

@Injectable()
export class NGOService {
  constructor(private prisma: PrismaService, private audit: AuditService) {}

  async apply(userId: string, dto: NGOApplicationDto) {
    const existing = await this.prisma.nGO.findUnique({ where: { userId } });
    if (existing) throw new ConflictException('NGO application already exists');

    const ngo = await this.prisma.nGO.create({
      data: { ...dto, userId, status: 'PENDING' },
    });
    await this.audit.log({ action: 'NGO_APPLIED', entityType: 'NGO', entityId: ngo.id, actorId: userId });
    return ngo;
  }

  async getProfile(userId: string) {
    const ngo = await this.prisma.nGO.findUnique({
      where: { userId },
      include: { campaigns: { where: { deletedAt: null }, orderBy: { createdAt: 'desc' } } },
    });
    if (!ngo) throw new NotFoundException('NGO not found');
    return ngo;
  }

  async approve(ngoId: string, adminId: string) {
    const ngo = await this.prisma.nGO.update({
      where: { id: ngoId },
      data: { status: 'APPROVED', verifiedAt: new Date(), verifiedBy: adminId },
    });
    await this.prisma.user.update({ where: { id: ngo.userId }, data: { twoFactorEnabled: false } }); // prompt 2FA
    await this.audit.log({ action: 'NGO_APPROVED', entityType: 'NGO', entityId: ngoId, actorId: adminId });
    return ngo;
  }

  async reject(ngoId: string, adminId: string, reason: string) {
    const ngo = await this.prisma.nGO.update({
      where: { id: ngoId },
      data: { status: 'REJECTED', rejectionReason: reason },
    });
    await this.audit.log({ action: 'NGO_REJECTED', entityType: 'NGO', entityId: ngoId, actorId: adminId });
    return ngo;
  }

  async requestWithdrawal(ngoId: string, amount: number, note?: string) {
    const ngo = await this.prisma.nGO.findUnique({ where: { id: ngoId } });
    if (!ngo) throw new NotFoundException();
    const available = Number(ngo.totalReceived) - Number(ngo.totalWithdrawn);
    if (amount > available) throw new ConflictException('Insufficient available balance');

    return this.prisma.withdrawalRequest.create({
      data: { ngoId, amount, currency: 'USD', requestNote: note },
    });
  }

  async getAnalytics(ngoId: string) {
    const [campaigns, donations, allocations] = await Promise.all([
      this.prisma.campaign.findMany({ where: { ngoId }, select: { id: true, title: true, raisedAmount: true, donorCount: true, status: true } }),
      this.prisma.donation.aggregate({ where: { campaign: { ngoId } }, _sum: { amountUsd: true }, _count: true }),
      this.prisma.fundAllocation.findMany({ where: { ngoId }, orderBy: { allocatedAt: 'desc' }, take: 10 }),
    ]);
    return { campaigns, donations, allocations };
  }
}


