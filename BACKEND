import { Injectable, NotFoundException, BadRequestException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { AuditService } from '../audit/audit.service';
import { CreateDonationDto } from './dto/create-donation.dto';
import { v4 as uuid } from 'uuid';

@Injectable()
export class DonationsService {
  constructor(
    private prisma: PrismaService,
    private audit: AuditService,
  ) {}

  async create(userId: string | null, dto: CreateDonationDto) {
    const campaign = await this.prisma.campaign.findUnique({ where: { id: dto.campaignId } });
    if (!campaign || campaign.status !== 'ACTIVE') throw new NotFoundException('Campaign not found or not active');

    const donation = await this.prisma.donation.create({
      data: {
        userId: dto.isAnonymous ? null : userId,
        campaignId: dto.campaignId,
        amount: dto.amount,
        currency: dto.currency ?? 'USD',
        amountUsd: dto.amount, // real system would apply exchange rate
        isAnonymous: dto.isAnonymous ?? false,
        message: dto.message,
        status: 'PENDING',
      },
    });

    if (userId) await this.audit.log({ action: 'DONATION_RECEIVED', entityType: 'Donation', entityId: donation.id, actorId: userId });
    return donation;
  }

  async findByUser(userId: string, page = 1, limit = 20) {
    const [data, total] = await this.prisma.$transaction([
      this.prisma.donation.findMany({
        where: { userId },
        include: { campaign: { select: { title: true, slug: true, coverImageUrl: true } } },
        orderBy: { createdAt: 'desc' },
        skip: (page - 1) * limit,
        take: limit,
      }),
      this.prisma.donation.count({ where: { userId } }),
    ]);
    return { data, total, page, limit };
  }

  async confirmDonation(donationId: string, providerTxId: string, idempotencyKey: string) {
    // Called from webhook handler after Stripe confirms payment
    return this.prisma.$transaction(async (tx) => {
      const donation = await tx.donation.findUnique({ where: { id: donationId } });
      if (!donation) throw new NotFoundException();
      if (donation.status !== 'PENDING') return donation; // idempotent

      const updated = await tx.donation.update({
        where: { id: donationId },
        data: { status: 'COMPLETED' },
      });

      await tx.transaction.create({
        data: {
          donationId,
          type: 'DONATION',
          status: 'COMPLETED',
          provider: 'STRIPE',
          providerTxId,
          idempotencyKey,
          amount: donation.amount,
          currency: donation.currency,
          amountUsd: donation.amountUsd,
          feeAmount: donation.amount.mul(0.029).plus(0.30), // Stripe fee
          netAmount: donation.amount.mul(0.971).minus(0.30),
          processedAt: new Date(),
        },
      });

      // Update campaign raised amount and donor count
      await tx.campaign.update({
        where: { id: donation.campaignId },
        data: {
          raisedAmount: { increment: donation.amountUsd },
          donorCount: { increment: 1 },
        },
      });

      // Update NGO total received
      const campaign = await tx.campaign.findUnique({ where: { id: donation.campaignId } });
      await tx.nGO.update({
        where: { id: campaign!.ngoId },
        data: { totalReceived: { increment: donation.amountUsd } },
      });

      // Update platform stats
      await tx.platformStats.upsert({
        where: { id: 'singleton' },
        update: { totalRaisedUsd: { increment: donation.amountUsd }, totalDonors: { increment: 1 } },
        create: { id: 'singleton', totalRaisedUsd: donation.amountUsd, totalDonors: 1 },
      });

      return updated;
    });
  }
}


