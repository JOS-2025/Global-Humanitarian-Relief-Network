import {
  Injectable, NotFoundException, ForbiddenException,
  BadRequestException,
} from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { RedisService } from '../redis/redis.service';
import { AuditService } from '../audit/audit.service';
import { CreateCampaignDto } from './dto/create-campaign.dto';
import { UpdateCampaignDto } from './dto/update-campaign.dto';
import { CampaignQueryDto } from './dto/campaign-query.dto';
import { Prisma } from '@prisma/client';

const CACHE_TTL = 60; // seconds

@Injectable()
export class CampaignsService {
  constructor(
    private prisma: PrismaService,
    private redis: RedisService,
    private audit: AuditService,
  ) {}

  async findAll(query: CampaignQueryDto) {
    const cacheKey = `campaigns:list:${JSON.stringify(query)}`;
    const cached = await this.redis.get(cacheKey);
    if (cached) return JSON.parse(cached);

    const where: Prisma.CampaignWhereInput = {
      status: 'ACTIVE',
      deletedAt: null,
      ...(query.region && { region: query.region }),
      ...(query.category && { category: query.category as any }),
      ...(query.urgency && { urgency: query.urgency as any }),
      ...(query.search && {
        OR: [
          { title: { contains: query.search, mode: 'insensitive' } },
          { shortSummary: { contains: query.search, mode: 'insensitive' } },
        ],
      }),
    };

    const [data, total] = await this.prisma.$transaction([
      this.prisma.campaign.findMany({
        where,
        include: { ngo: { select: { organizationName: true, country: true } } },
        orderBy: [{ isFeatured: 'desc' }, { urgency: 'desc' }, { createdAt: 'desc' }],
        skip: (query.page - 1) * query.limit,
        take: query.limit,
      }),
      this.prisma.campaign.count({ where }),
    ]);

    const result = { data, total, page: query.page, limit: query.limit };
    await this.redis.set(cacheKey, JSON.stringify(result), CACHE_TTL);
    return result;
  }

  async findOne(slug: string) {
    const cacheKey = `campaigns:${slug}`;
    const cached = await this.redis.get(cacheKey);
    if (cached) return JSON.parse(cached);

    const campaign = await this.prisma.campaign.findUnique({
      where: { slug, deletedAt: null },
      include: {
        ngo: { select: { organizationName: true, country: true, status: true } },
        impactReports: { where: { isPublished: true }, orderBy: { publishedAt: 'desc' }, take: 5 },
        fundAllocations: { where: { isPublic: true }, orderBy: { allocatedAt: 'desc' }, take: 10 },
        updates: { orderBy: { publishedAt: 'desc' }, take: 5 },
      },
    });
    if (!campaign) throw new NotFoundException('Campaign not found');

    await this.redis.set(cacheKey, JSON.stringify(campaign), CACHE_TTL);
    return campaign;
  }

  async create(ngoId: string, userId: string, dto: CreateCampaignDto) {
    const ngo = await this.prisma.nGO.findUnique({ where: { id: ngoId } });
    if (!ngo || ngo.status !== 'APPROVED') throw new ForbiddenException('NGO not approved');

    const slug = this.slugify(dto.title);
    const existing = await this.prisma.campaign.findUnique({ where: { slug } });
    if (existing) throw new BadRequestException('Campaign title already exists');

    const campaign = await this.prisma.campaign.create({
      data: { ...dto, ngoId, slug, status: 'PENDING_APPROVAL' },
    });

    await this.audit.log({ action: 'CAMPAIGN_CREATED', entityType: 'Campaign', entityId: campaign.id, actorId: userId });
    return campaign;
  }

  async update(id: string, ngoId: string, dto: UpdateCampaignDto) {
    const campaign = await this.prisma.campaign.findUnique({ where: { id } });
    if (!campaign) throw new NotFoundException();
    if (campaign.ngoId !== ngoId) throw new ForbiddenException();

    // Invalidate cache
    await this.redis.del(`campaigns:${campaign.slug}`);
    return this.prisma.campaign.update({ where: { id }, data: dto });
  }

  async approve(id: string, adminId: string) {
    const campaign = await this.prisma.campaign.findUnique({ where: { id } });
    if (!campaign) throw new NotFoundException();

    const updated = await this.prisma.campaign.update({
      where: { id },
      data: { status: 'ACTIVE', approvedAt: new Date(), approvedBy: adminId },
    });
    await this.audit.log({ action: 'CAMPAIGN_APPROVED', entityType: 'Campaign', entityId: id, actorId: adminId });
    return updated;
  }

  async reject(id: string, adminId: string, reason: string) {
    const updated = await this.prisma.campaign.update({
      where: { id },
      data: { status: 'REJECTED', rejectionReason: reason },
    });
    await this.audit.log({ action: 'CAMPAIGN_REJECTED', entityType: 'Campaign', entityId: id, actorId: adminId });
    return updated;
  }

  private slugify(title: string): string {
    return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
      + '-' + Date.now().toString(36);
  }
}


