import { Injectable, NotFoundException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { AuditService } from '../audit/audit.service';

@Injectable()
export class AdminService {
  constructor(private prisma: PrismaService, private audit: AuditService) {}

  async getDashboardStats() {
    const [users, ngos, campaigns, donations, alerts] = await Promise.all([
      this.prisma.user.count(),
      this.prisma.nGO.groupBy({ by: ['status'], _count: true }),
      this.prisma.campaign.groupBy({ by: ['status'], _count: true }),
      this.prisma.donation.aggregate({ _sum: { amountUsd: true }, _count: true }),
      this.prisma.complianceAlert.count({ where: { isResolved: false } }),
    ]);
    return { users, ngos, campaigns, donations, openAlerts: alerts };
  }

  async getPendingNGOs() {
    return this.prisma.nGO.findMany({
      where: { status: 'PENDING' },
      include: { user: { select: { email: true, createdAt: true } }, documents: true },
      orderBy: { createdAt: 'asc' },
    });
  }

  async getPendingCampaigns() {
    return this.prisma.campaign.findMany({
      where: { status: 'PENDING_APPROVAL' },
      include: { ngo: { select: { organizationName: true, status: true } } },
      orderBy: { createdAt: 'asc' },
    });
  }

  async suspendUser(targetId: string, adminId: string, reason: string) {
    await this.prisma.user.update({ where: { id: targetId }, data: { status: 'SUSPENDED' } });
    await this.audit.log({ action: 'USER_SUSPENDED', entityType: 'User', entityId: targetId, actorId: adminId, metadata: { reason } });
  }

  async freezeAccount(ngoId: string, adminId: string, reason: string) {
    await this.prisma.nGO.update({ where: { id: ngoId }, data: { status: 'SUSPENDED' } });
    await this.audit.log({ action: 'ACCOUNT_FROZEN', entityType: 'NGO', entityId: ngoId, actorId: adminId, metadata: { reason } });
    await this.prisma.complianceAlert.create({
      data: { ngoId, entityType: 'NGO', entityId: ngoId, severity: 'CRITICAL', title: 'Account frozen', description: reason },
    });
  }

  async getAuditLog(page = 1, limit = 50) {
    return this.prisma.auditLog.findMany({
      include: { actor: { select: { email: true, role: true } } },
      orderBy: { createdAt: 'desc' },
      skip: (page - 1) * limit,
      take: limit,
    });
  }

  async getComplianceAlerts(resolved = false) {
    return this.prisma.complianceAlert.findMany({
      where: { isResolved: resolved },
      orderBy: [{ severity: 'desc' }, { createdAt: 'desc' }],
    });
  }

  async processWithdrawal(id: string, adminId: string, approved: boolean, note?: string) {
    const request = await this.prisma.withdrawalRequest.findUnique({ where: { id }, include: { ngo: true } });
    if (!request) throw new NotFoundException();

    const status = approved ? 'APPROVED' : 'REJECTED';
    await this.prisma.withdrawalRequest.update({
      where: { id },
      data: { status, reviewedBy: adminId, reviewedAt: new Date(), reviewNote: note },
    });
    if (approved) {
      await this.prisma.nGO.update({
        where: { id: request.ngoId },
        data: { totalWithdrawn: { increment: request.amount } },
      });
    }
    const action = approved ? 'WITHDRAWAL_APPROVED' : 'WITHDRAWAL_REJECTED';
    await this.audit.log({ action, entityType: 'WithdrawalRequest', entityId: id, actorId: adminId });
  }
}


